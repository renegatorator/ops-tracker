NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Postgres password (Database Settings in Supabase dashboard)
SUPABASE_DB_PASSWORD=your-database-password
# Optional; defaults to http://localhost:3000 when unset
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Optional — transactional email via Resend (server-only; never use NEXT_PUBLIC_)
# https://resend.com/docs/send-with-nextjs
# RESEND_API_KEY=re_xxxxxxxx
# Verified sender in production, e.g. "Ops Tracker <mail@yourdomain.com>"
# RESEND_FROM=Ops Tracker <onboarding@resend.dev>

# Optional — Playwright (npm run test:e2e); user must exist in Supabase and have ≥1 issue
# E2E_EMAIL=you@example.com
# E2E_PASSWORD=your-password
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
